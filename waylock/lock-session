#!/bin/bash
set -e

if [ -n "$1" ]; then
    file="$1"
elif [ -n "$WAYLOCK_VIDEO" ]; then
    file="$WAYLOCK_VIDEO"
fi

if [ -z "$file" ]; then
    exec waylock
fi

if [[ "$file" == *.bgra ]]; then
    # Raw BGRA file — dimensions and fps encoded in filename as <name>-WxH@Nfps.bgra
    base=$(basename "$file" .bgra)
    dims=$(echo "$base" | grep -oE '[0-9]+x[0-9]+')
    w=${dims%x*}
    h=${dims#*x}
    fps=$(echo "$base" | grep -oE '@[0-9]+fps' | grep -oE '[0-9]+')
    exec waylock \
        -animation-fd 3 \
        -animation-width "$w" \
        -animation-height "$h" \
        ${fps:+-animation-fps "$fps"} \
        3< <(while true; do cat "$file"; done)
fi

read -r w h < <(ffprobe -v error -select_streams v:0 \
    -show_entries stream=width,height \
    -of csv=p=0 "$file" | tr ',' ' ')

fps=$(ffprobe -v error -select_streams v:0 \
    -show_entries stream=r_frame_rate \
    -of csv=p=0 "$file" | awk -F/ '{printf "%d", $1/$2}')

exec waylock \
    -animation-fd 3 \
    -animation-width "$w" \
    -animation-height "$h" \
    -animation-fps "$fps" \
    3< <(ffmpeg -nostdin -stream_loop -1 -i "$file" \
         -an -f rawvideo -pix_fmt bgra - 2>/dev/null)
